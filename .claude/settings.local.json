{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Bash(pip install*)",
      "Bash(npm*)",
      "Bash(npx*)",
      "Bash(cd*)",
      "Bash(dir*)",
      "Bash(type*)",
      "Bash(cat*)",
      "Bash(python*)",
      "Bash(alembic*)",
      "Bash(docker*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git commit*)",
      "Bash(rm -rf*)",
      "Bash(del /s*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_TOOL_ARGS\" == *\"backend/\"*\".py\"* ]]; then cd backend && ruff check .; fi"
          }
        ]
      }
    ]
  }
}